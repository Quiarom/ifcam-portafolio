---
import Layout from './Layout.astro';
import type { CollectionEntry } from 'astro:content';

type Props = {
  post: CollectionEntry<'portfolio'>;
};

const { post } = Astro.props;
const { title, description, publishDate, image, client, country, industry, services, author } = post.data;
---

<Layout title={title} description={description}>
  <!-- Two Column Layout Container -->
  <div class="portfolio-layout">
    
    <!-- Left Sidebar (Sticky) -->
    <aside class="portfolio-sidebar" id="portfolioSidebar">
      <div class="sidebar-content">
        
        <!-- Project Hero Info -->
        <div class="project-hero">
          <div class="project-meta">
            <span class="industry-tag">
              {industry}
            </span>
            <time class="publish-date">
              {publishDate.toLocaleDateString('en-US', {
                year: 'numeric',
                month: 'long',
                day: 'numeric'
              })}
            </time>
          </div>
          
          <h1 class="project-title">
            {title}
          </h1>
          
          <p class="project-description">
            {description}
          </p>
        </div>

        <!-- Project Details -->
        <div class="project-details">
          <h3 class="details-title">Project Details</h3>
          <div class="details-grid">
            <div class="detail-item">
              <h4 class="detail-label">CLIENT</h4>
              <p class="detail-value">{client}</p>
            </div>
            <div class="detail-item">
              <h4 class="detail-label">INDUSTRY</h4>
              <p class="detail-value">{industry}</p>
            </div>
            <div class="detail-item">
              <h4 class="detail-label">LOCATION</h4>
              <p class="detail-value">{country}</p>
            </div>
            <div class="detail-item">
              <h4 class="detail-label">COMPLETED</h4>
              <p class="detail-value">
                {publishDate.toLocaleDateString('en-US', {
                  year: 'numeric',
                  month: 'long'
                })}
              </p>
            </div>
          </div>
        </div>

        <!-- Services Tags -->
        <div class="services-section">
          <h3 class="services-title">Services</h3>
          <div class="services-tags">
            {services.map((service) => (
              <span class="service-tag">
                {service}
              </span>
            ))}
          </div>
        </div>

        <!-- Navigation Links -->
        <div class="navigation-section">
          <h3 class="nav-title">Navigation</h3>
          <div class="nav-links">
            <a href="/portfolio" class="nav-link back-link">
              <span class="nav-arrow">←</span> Back to Portfolio
            </a>
            <a href="/about" class="nav-link">
              About Me <span class="nav-arrow">→</span>
            </a>
          </div>
        </div>

        <!-- Author Info -->
        <div class="author-section">
          <h3 class="author-title">Project by</h3>
          <div class="author-info">
            <img
              src="https://avatars.githubusercontent.com/u/890270?v=4"
              alt={author}
              class="author-avatar"
            />
            <div class="author-details">
              <p class="author-name">{author}</p>
              <p class="author-role">Full-Stack Developer</p>
            </div>
          </div>
        </div>
      </div>
    </aside>

    <!-- Right Content Area -->
    <main class="portfolio-content">
      
      <!-- Featured Image -->
      {image && (
        <div class="featured-image">
          <img
            src={image.src}
            alt={image.alt}
            class="content-image"
          />
        </div>
      )}

      <!-- Article Content -->
      <article class="article-content">
        <slot />
      </article>
    </main>
  </div>
</Layout>

<style>
  /* Main Layout Container */
  .portfolio-layout {
    display: grid;
    grid-template-columns: 300px 1fr;
    min-height: 100vh;
    background-color: #ffffff;
  }

  /* Sidebar Styles */
  .portfolio-sidebar {
    position: fixed;
    top: 0;
    left: 0;
    width: 300px;
    height: 100vh;
    background-color: #f8fafc;
    border-right: 1px solid #e2e8f0;
    overflow-y: auto;
    z-index: 40;
    scrollbar-width: thin;
    scrollbar-color: #cbd5e0 transparent;
  }

  .portfolio-sidebar::-webkit-scrollbar {
    width: 6px;
  }

  .portfolio-sidebar::-webkit-scrollbar-track {
    background: transparent;
  }

  .portfolio-sidebar::-webkit-scrollbar-thumb {
    background-color: #cbd5e0;
    border-radius: 3px;
  }

  .sidebar-content {
    padding: 2rem 1.5rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
  }

  /* Project Hero */
  .project-hero {
    border-bottom: 1px solid #e2e8f0;
    padding-bottom: 2rem;
  }

  .project-meta {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
    margin-bottom: 1.5rem;
  }

  .industry-tag {
    display: inline-block;
    padding: 0.5rem 1rem;
    background-color: #2563eb;
    color: white;
    font-size: 0.75rem;
    font-weight: 600;
    border-radius: 9999px;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    width: fit-content;
  }

  .publish-date {
    font-size: 0.875rem;
    color: #64748b;
    font-weight: 500;
  }

  .project-title {
    font-size: 1.5rem;
    font-weight: 700;
    color: #1e293b;
    line-height: 1.3;
    margin-bottom: 1rem;
  }

  .project-description {
    font-size: 0.875rem;
    color: #475569;
    line-height: 1.6;
    margin: 0;
  }

  /* Project Details */
  .project-details {
    background-color: #ffffff;
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .details-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .details-grid {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }

  .detail-item {
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .detail-label {
    font-size: 0.75rem;
    font-weight: 600;
    color: #64748b;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    margin: 0;
  }

  .detail-value {
    font-size: 0.875rem;
    font-weight: 500;
    color: #1e293b;
    margin: 0;
  }

  /* Services Section */
  .services-section {
    background-color: #ffffff;
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .services-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .services-tags {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
  }

  .service-tag {
    display: inline-block;
    padding: 0.375rem 0.75rem;
    background-color: #f1f5f9;
    color: #2563eb;
    font-size: 0.75rem;
    font-weight: 500;
    border-radius: 9999px;
    border: 1px solid #e2e8f0;
    transition: all 0.2s ease;
  }

  .service-tag:hover {
    background-color: #e2e8f0;
    transform: translateY(-1px);
  }

  /* Navigation Section */
  .navigation-section {
    background-color: #ffffff;
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .nav-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .nav-links {
    display: flex;
    flex-direction: column;
    gap: 0.75rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    color: #2563eb;
    text-decoration: none;
    font-size: 0.875rem;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .nav-link:hover {
    color: #1d4ed8;
  }

  .nav-arrow {
    transition: transform 0.2s ease;
  }

  .back-link:hover .nav-arrow {
    transform: translateX(-2px);
  }

  .nav-link:not(.back-link):hover .nav-arrow {
    transform: translateX(2px);
  }

  /* Author Section */
  .author-section {
    background-color: #ffffff;
    border-radius: 0.75rem;
    padding: 1.5rem;
    border: 1px solid #e2e8f0;
  }

  .author-title {
    font-size: 1rem;
    font-weight: 600;
    color: #1e293b;
    margin-bottom: 1rem;
  }

  .author-info {
    display: flex;
    align-items: center;
    gap: 0.75rem;
  }

  .author-avatar {
    width: 3rem;
    height: 3rem;
    border-radius: 50%;
    object-fit: cover;
    border: 2px solid #e2e8f0;
  }

  .author-details {
    flex: 1;
  }

  .author-name {
    font-size: 0.875rem;
    font-weight: 600;
    color: #1e293b;
    margin: 0 0 0.25rem 0;
  }

  .author-role {
    font-size: 0.75rem;
    color: #64748b;
    margin: 0;
  }

  /* Content Area */
  .portfolio-content {
    margin-left: 300px;
    min-height: 100vh;
    background-color: #ffffff;
  }

  .featured-image {
    width: 100%;
    height: 60vh;
    overflow: hidden;
    background-color: #f1f5f9;
  }

  .content-image {
    width: 100%;
    height: 100%;
    object-fit: cover;
  }

  .article-content {
    max-width: 800px;
    margin: 0 auto;
    padding: 3rem 2rem;
  }

  /* Article Content Styles */
  .article-content :global(h1),
  .article-content :global(h2),
  .article-content :global(h3),
  .article-content :global(h4) {
    font-weight: 700;
    color: #1e293b;
    margin-top: 2.5rem;
    margin-bottom: 1rem;
    line-height: 1.3;
  }

  .article-content :global(h1) { font-size: 2.25rem; }
  .article-content :global(h2) { font-size: 1.875rem; }
  .article-content :global(h3) { font-size: 1.5rem; }
  .article-content :global(h4) { font-size: 1.25rem; }

  .article-content :global(p) {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin-bottom: 1.5rem;
  }

  .article-content :global(ul),
  .article-content :global(ol) {
    margin-bottom: 1.5rem;
    padding-left: 1.5rem;
  }

  .article-content :global(li) {
    font-size: 1rem;
    line-height: 1.7;
    color: #475569;
    margin-bottom: 0.5rem;
  }

  .article-content :global(blockquote) {
    border-left: 4px solid #2563eb;
    padding-left: 1.5rem;
    margin: 2rem 0;
    font-style: italic;
    color: #64748b;
    background-color: #f8fafc;
    padding: 1.5rem;
    border-radius: 0.5rem;
  }

  .article-content :global(code) {
    background-color: #f1f5f9;
    color: #1e293b;
    padding: 0.25rem 0.5rem;
    border-radius: 0.25rem;
    font-size: 0.875rem;
    font-family: 'Monaco', 'Menlo', 'Ubuntu Mono', monospace;
  }

  .article-content :global(pre) {
    background-color: #1e293b;
    color: #f8fafc;
    padding: 1.5rem;
    border-radius: 0.75rem;
    overflow-x: auto;
    margin: 2rem 0;
    font-size: 0.875rem;
    line-height: 1.6;
  }

  .article-content :global(pre code) {
    background-color: transparent;
    color: inherit;
    padding: 0;
  }

  .article-content :global(img) {
    width: 100%;
    height: auto;
    border-radius: 0.75rem;
    margin: 2rem 0;
    box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1);
  }

  .article-content :global(a) {
    color: #2563eb;
    text-decoration: none;
    font-weight: 500;
    transition: color 0.2s ease;
  }

  .article-content :global(a:hover) {
    color: #1d4ed8;
    text-decoration: underline;
  }

  /* Responsive Design */
  @media (max-width: 1024px) {
    .portfolio-layout {
      grid-template-columns: 1fr;
    }

    .portfolio-sidebar {
      position: relative;
      width: 100%;
      height: auto;
      border-right: none;
      border-bottom: 1px solid #e2e8f0;
    }

    .portfolio-content {
      margin-left: 0;
    }

    .sidebar-content {
      padding: 1.5rem;
      gap: 1.5rem;
    }

    .project-title {
      font-size: 1.25rem;
    }

    .featured-image {
      height: 40vh;
    }

    .article-content {
      padding: 2rem 1.5rem;
    }

    .article-content :global(h1) { font-size: 1.875rem; }
    .article-content :global(h2) { font-size: 1.5rem; }
    .article-content :global(h3) { font-size: 1.25rem; }
    .article-content :global(h4) { font-size: 1.125rem; }
  }

  @media (max-width: 768px) {
    .sidebar-content {
      padding: 1rem;
      gap: 1rem;
    }

    .project-details,
    .services-section,
    .navigation-section,
    .author-section {
      padding: 1rem;
    }

    .featured-image {
      height: 30vh;
    }

    .article-content {
      padding: 1.5rem 1rem;
    }
  }

  /* Dark Mode Support */
  :global(.dark) .portfolio-layout {
    background-color: #0f172a;
  }

  :global(.dark) .portfolio-sidebar {
    background-color: #1e293b;
    border-color: #334155;
  }

  :global(.dark) .portfolio-content {
    background-color: #0f172a;
  }

  :global(.dark) .project-title,
  :global(.dark) .details-title,
  :global(.dark) .services-title,
  :global(.dark) .nav-title,
  :global(.dark) .author-title,
  :global(.dark) .detail-value,
  :global(.dark) .author-name {
    color: #f8fafc;
  }

  :global(.dark) .project-description,
  :global(.dark) .publish-date,
  :global(.dark) .detail-label,
  :global(.dark) .author-role {
    color: #94a3b8;
  }

  :global(.dark) .project-details,
  :global(.dark) .services-section,
  :global(.dark) .navigation-section,
  :global(.dark) .author-section {
    background-color: #334155;
    border-color: #475569;
  }

  :global(.dark) .service-tag {
    background-color: #475569;
    color: #60a5fa;
    border-color: #64748b;
  }

  :global(.dark) .service-tag:hover {
    background-color: #64748b;
  }

  :global(.dark) .nav-link {
    color: #60a5fa;
  }

  :global(.dark) .nav-link:hover {
    color: #93c5fd;
  }

  :global(.dark) .industry-tag {
    background-color: #60a5fa;
    color: #0f172a;
  }

  :global(.dark) .featured-image {
    background-color: #334155;
  }

  :global(.dark) .article-content :global(h1),
  :global(.dark) .article-content :global(h2),
  :global(.dark) .article-content :global(h3),
  :global(.dark) .article-content :global(h4) {
    color: #f8fafc;
  }

  :global(.dark) .article-content :global(p),
  :global(.dark) .article-content :global(li) {
    color: #cbd5e1;
  }

  :global(.dark) .article-content :global(blockquote) {
    background-color: #334155;
    color: #94a3b8;
    border-color: #60a5fa;
  }

  :global(.dark) .article-content :global(code) {
    background-color: #334155;
    color: #f8fafc;
  }

  :global(.dark) .article-content :global(a) {
    color: #60a5fa;
  }

  :global(.dark) .article-content :global(a:hover) {
    color: #93c5fd;
  }
</style>

<script>
  function initializeStickyBehavior() {
    const sidebar = document.getElementById('portfolioSidebar');
    if (!sidebar) return;

    // Hide header when sidebar is sticky on desktop
    const header = document.querySelector('header');
    
    function handleScroll() {
      if (window.innerWidth > 1024) {
        if (window.scrollY > 0) {
          header?.style.setProperty('transform', 'translateY(-100%)');
          header?.style.setProperty('transition', 'transform 0.3s ease');
        } else {
          header?.style.setProperty('transform', 'translateY(0)');
        }
      } else {
        header?.style.setProperty('transform', 'translateY(0)');
      }
    }

    function handleResize() {
      if (window.innerWidth <= 1024) {
        header?.style.setProperty('transform', 'translateY(0)');
      }
    }

    window.addEventListener('scroll', handleScroll);
    window.addEventListener('resize', handleResize);

    // Initial check
    handleScroll();
    handleResize();

    // Cleanup function
    return () => {
      window.removeEventListener('scroll', handleScroll);
      window.removeEventListener('resize', handleResize);
    };
  }

  // Initialize when DOM is ready
  if (document.readyState === 'loading') {
    document.addEventListener('DOMContentLoaded', initializeStickyBehavior);
  } else {
    initializeStickyBehavior();
  }
</script>
</Layout>